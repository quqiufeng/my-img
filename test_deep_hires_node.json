{
    "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
            "ckpt_name": "/path/to/model.gguf"
        }
    },
    "2": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "masterpiece, best quality, a beautiful sunset over mountains",
            "clip": ["1", 1]
        }
    },
    "3": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "worst quality, low quality, blurry",
            "clip": ["1", 1]
        }
    },
    "4": {
        "class_type": "DeepHighResFix",
        "inputs": {
            "model": ["1", 0],
            "positive": ["2", 0],
            "negative": ["3", 0],
            "seed": 42,
            "steps": 30,
            "cfg": 7.0,
            "target_width": 1024,
            "target_height": 1024,
            "strength": 1.0,
            "vae_tiling": false
        }
    },
    "5": {
        "class_type": "SaveImage",
        "inputs": {
            "images": ["4", 0],
            "filename_prefix": "deep_hires_output"
        }
    }
}
