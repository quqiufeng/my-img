+// ============================================================================
+// ComfyUI-style Node-level API - Added by my-img project
+// ============================================================================
+
+struct sd_latent_t {
+    sd::Tensor<float> tensor;
+};
+
+struct sd_conditioning_t {
+    SDCondition cond;
+};
+
+SD_API sd_conditioning_t* sd_encode_prompt(
+    sd_ctx_t* sd_ctx,
+    const char* prompt,
+    int clip_skip) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || prompt == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->cond_stage_model == nullptr) {
+        LOG_ERROR("cond_stage_model is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0 = ggml_time_ms();
+    ConditionerParams condition_params;
+    condition_params.text = prompt;
+    condition_params.clip_skip = clip_skip;
+    condition_params.width = 512;   // default, will be overridden by KSampler
+    condition_params.height = 512;  // default
+    condition_params.adm_in_channels = static_cast<int>(sd_ctx->sd->diffusion_model->get_adm_in_channels());
+
+    auto cond = sd_ctx->sd->cond_stage_model->get_learned_condition(
+        sd_ctx->sd->n_threads, condition_params);
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_encode_prompt completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    sd_conditioning_t* result = new sd_conditioning_t();
+    result->cond = std::move(cond);
+    return result;
+}
+
+SD_API void sd_free_conditioning(sd_conditioning_t* cond) {
+    delete cond;
+}
+
+SD_API sd_latent_t* sd_create_empty_latent(
+    sd_ctx_t* sd_ctx,
+    int width,
+    int height) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr) {
+        return nullptr;
+    }
+
+    // Align dimensions to VAE scale factor
+    int vae_scale = sd_ctx->sd->first_stage_model ?
+        sd_ctx->sd->first_stage_model->get_scale_factor() : 8;
+    int latent_w = width / vae_scale;
+    int latent_h = height / vae_scale;
+
+    // Standard SD latent shape: [batch=1, channels=4, height, width]
+    sd::Tensor<float> latent({latent_w, latent_h, 4, 1});
+    latent.fill_(0.0f);
+
+    sd_latent_t* result = new sd_latent_t();
+    result->tensor = std::move(latent);
+    return result;
+}
+
+SD_API sd_latent_t* sd_encode_image(
+    sd_ctx_t* sd_ctx,
+    const sd_image_t* image) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || image == nullptr || image->data == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->first_stage_model == nullptr) {
+        LOG_ERROR("first_stage_model (VAE) is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0 = ggml_time_ms();
+    sd::Tensor<float> image_tensor = sd_image_to_tensor(*image, image->width, image->height);
+    sd::Tensor<float> latent = sd_ctx->sd->encode_first_stage(image_tensor);
+
+    if (latent.empty()) {
+        LOG_ERROR("encode_first_stage failed");
+        return nullptr;
+    }
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_encode_image completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    if (sd_ctx->sd->free_params_immediately) {
+        sd_ctx->sd->first_stage_model->free_params_buffer();
+    }
+
+    sd_latent_t* result = new sd_latent_t();
+    result->tensor = std::move(latent);
+    return result;
+}
+
+SD_API sd_image_t* sd_decode_latent(
+    sd_ctx_t* sd_ctx,
+    const sd_latent_t* latent) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || latent == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->first_stage_model == nullptr) {
+        LOG_ERROR("first_stage_model (VAE) is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0 = ggml_time_ms();
+    sd::Tensor<float> image_tensor = sd_ctx->sd->decode_first_stage(latent->tensor);
+
+    if (image_tensor.empty()) {
+        LOG_ERROR("decode_first_stage failed");
+        if (sd_ctx->sd->free_params_immediately) {
+            sd_ctx->sd->first_stage_model->free_params_buffer();
+        }
+        return nullptr;
+    }
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_decode_latent completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    if (sd_ctx->sd->free_params_immediately) {
+        sd_ctx->sd->first_stage_model->free_params_buffer();
+    }
+
+    sd_image_t* result = (sd_image_t*)malloc(sizeof(sd_image_t));
+    if (result == nullptr) {
+        return nullptr;
+    }
+    *result = tensor_to_sd_image(image_tensor);
+    return result;
+}
+
+SD_API void sd_free_latent(sd_latent_t* latent) {
+    delete latent;
+}
+
+SD_API void sd_free_image(sd_image_t* image) {
+    if (image) {
+        if (image->data) {
+            free(image->data);
+            image->data = nullptr;
+        }
+        free(image);
+    }
+}
+
+SD_API void sd_latent_get_shape(
+    const sd_latent_t* latent,
+    int* width,
+    int* height,
+    int* channels) {
+    if (latent == nullptr || latent->tensor.empty()) {
+        if (width) *width = 0;
+        if (height) *height = 0;
+        if (channels) *channels = 0;
+        return;
+    }
+    const auto& shape = latent->tensor.shape();
+    // Typical shape: [W, H, C, 1] or [W, H, C]
+    if (width) *width = static_cast<int>(shape[0]);
+    if (height) *height = static_cast<int>(shape[1]);
+    if (channels) *channels = static_cast<int>(shape[2]);
+}
+
+SD_API sd_latent_t* sd_latent_copy(const sd_latent_t* latent) {
+    if (latent == nullptr) return nullptr;
+    sd_latent_t* copy = new sd_latent_t();
+    copy->tensor = latent->tensor;  // sd::Tensor has value semantics
+    return copy;
+}
+
+SD_API sd_conditioning_t* sd_conditioning_copy(const sd_conditioning_t* cond) {
+    if (cond == nullptr) return nullptr;
+    sd_conditioning_t* copy = new sd_conditioning_t();
+    copy->cond = cond->cond;  // SDCondition has value semantics
+    return copy;
+}
+
+SD_API sd_latent_t* sd_sampler_run(
+    sd_ctx_t* sd_ctx,
+    const sd_latent_t* init_latent,
+    const sd_conditioning_t* positive,
+    const sd_conditioning_t* negative,
+    const sd_node_sample_params_t* params,
+    float strength) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || init_latent == nullptr ||
+        positive == nullptr || params == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->diffusion_model == nullptr) {
+        LOG_ERROR("diffusion_model is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0 = ggml_time_ms();
+
+    // Setup RNGs
+    sd_ctx->sd->rng->manual_seed(params->seed);
+    if (sd_ctx->sd->sampler_rng) {
+        sd_ctx->sd->sampler_rng->manual_seed(params->seed);
+    }
+
+    // Build sigma schedule using the denoiser
+    int total_steps = params->steps;
+    scheduler_t scheduler = params->scheduler;
+    
+    // Get image sequence length for the denoiser
+    int image_seq_len = sd_ctx->sd->get_image_seq_len(
+        init_latent->tensor.shape()[1] * 8,  // height * vae_scale
+        init_latent->tensor.shape()[0] * 8   // width * vae_scale
+    );
+    
+    std::vector<float> sigmas = sd_ctx->sd->denoiser->get_sigmas(
+        total_steps,
+        image_seq_len,
+        scheduler,
+        sd_ctx->sd->version
+    );
+
+    if (sigmas.empty()) {
+        LOG_ERROR("failed to generate sigma schedule");
+        return nullptr;
+    }
+
+    // Adjust sigmas for strength (img2img)
+    if (strength < 1.0f && sigmas.size() > 1) {
+        int start_step = static_cast<int>((1.0f - strength) * (sigmas.size() - 1));
+        sigmas = std::vector<float>(sigmas.begin() + start_step, sigmas.end());
+    }
+
+    // Prepare noise
+    sd::Tensor<float> noise = sd::randn_like<float>(init_latent->tensor, sd_ctx->sd->rng);
+
+    // Prepare guidance
+    sd_guidance_params_t guidance;
+    guidance.txt_cfg = params->cfg_scale;
+    guidance.img_cfg = 1.0f;
+    guidance.distilled_guidance = 0.0f;
+    guidance.slg.scale = 0.0f;
+
+    // Use empty conditioning for negative if not provided
+    SDCondition uncond;
+    if (negative != nullptr) {
+        uncond = negative->cond;
+    }
+
+    // Setup cache params (disabled by default for node API)
+    sd_cache_params_t cache_params;
+    sd_cache_params_init(&cache_params);
+    cache_params.mode = SD_CACHE_DISABLED;
+
+    // Run sampling
+    sd::Tensor<float> x_0 = sd_ctx->sd->sample(
+        sd_ctx->sd->diffusion_model,
+        true,  // is_image_generation
+        init_latent->tensor,
+        std::move(noise),
+        positive->cond,
+        uncond,
+        SDCondition(),  // img_cond
+        SDCondition(),  // id_cond
+        sd::Tensor<float>(),  // control_image
+        0.0f,  // control_strength
+        guidance,
+        params->eta,
+        0,     // shifted_timestep
+        params->sample_method,
+        sd_ctx->sd->is_flow_denoiser(),
+        sigmas,
+        -1,    // start_merge_step
+        {},    // ref_latents
+        false, // increase_ref_index
+        sd::Tensor<float>(),  // denoise_mask
+        sd::Tensor<float>(),  // vace_context
+        1.0f,  // vace_strength
+        &cache_params
+    );
+
+    if (sd_ctx->sd->free_params_immediately) {
+        sd_ctx->sd->diffusion_model->free_params_buffer();
+    }
+
+    if (x_0.empty()) {
+        LOG_ERROR("sampling failed");
+        return nullptr;
+    }
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_sampler_run completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    sd_latent_t* result = new sd_latent_t();
+    result->tensor = std::move(x_0);
+    return result;
+}
