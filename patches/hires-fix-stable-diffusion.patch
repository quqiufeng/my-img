+SD_API sd_latent_t* sd_latent_copy(const sd_latent_t* latent) {
+    if (latent == nullptr)
+        return nullptr;
+    sd_latent_t* copy = new sd_latent_t();
+    copy->tensor      = latent->tensor;  // sd::Tensor has value semantics
+    return copy;
+}
