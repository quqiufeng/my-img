+SD_API void sd_latent_get_shape(
+    const sd_latent_t* latent,
+    int* width,
+    int* height,
+    int* channels) {
+    if (latent == nullptr || latent->tensor.empty()) {
+        if (width)
+            *width = 0;
+        if (height)
+            *height = 0;
+        if (channels)
+            *channels = 0;
+        return;
+    }
+    const auto& shape = latent->tensor.shape();
+    // Typical shape: [W, H, C, 1] or [W, H, C]
+    if (width)
+        *width = static_cast<int>(shape[0]);
+    if (height)
+        *height = static_cast<int>(shape[1]);
+    if (channels)
+        *channels = static_cast<int>(shape[2]);
+}
