+SD_API sd_conditioning_t* sd_conditioning_copy(const sd_conditioning_t* cond) {
+    if (cond == nullptr)
+        return nullptr;
+    sd_conditioning_t* copy = new sd_conditioning_t();
+    copy->cond              = cond->cond;  // SDCondition has value semantics
+    return copy;
+}
