+// sd_latent_t 定义在 stable-diffusion-ext.h 中
+// sd_conditioning_t 定义如下
+struct sd_conditioning_t {
+    SDCondition cond;
+};
+
+SD_API sd_conditioning_t* sd_encode_prompt(
+    sd_ctx_t* sd_ctx,
+    const char* prompt,
+    int clip_skip) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || prompt == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->cond_stage_model == nullptr) {
+        LOG_ERROR("cond_stage_model is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0 = ggml_time_ms();
+    ConditionerParams condition_params;
+    condition_params.text            = prompt;
+    condition_params.clip_skip       = clip_skip;
+    condition_params.width           = 512;  // default, will be overridden by KSampler
+    condition_params.height          = 512;  // default
+    condition_params.adm_in_channels = static_cast<int>(sd_ctx->sd->diffusion_model->get_adm_in_channels());
+
+    auto cond = sd_ctx->sd->cond_stage_model->get_learned_condition(
+        sd_ctx->sd->n_threads, condition_params);
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_encode_prompt completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    sd_conditioning_t* result = new sd_conditioning_t();
+    result->cond              = std::move(cond);
+    return result;
+}
+
+SD_API void sd_free_conditioning(sd_conditioning_t* cond) {
+    delete cond;
+}
+
+SD_API sd_latent_t* sd_create_empty_latent(
+    sd_ctx_t* sd_ctx,
+    int width,
+    int height) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr) {
+        return nullptr;
+    }
+
+    // Align dimensions to VAE scale factor
+    int vae_scale = sd_ctx->sd->first_stage_model ? sd_ctx->sd->first_stage_model->get_scale_factor() : 8;
+    int latent_w  = width / vae_scale;
+    int latent_h  = height / vae_scale;
+
+    // Standard SD latent shape: [batch=1, channels=4, height, width]
+    sd::Tensor<float> latent({latent_w, latent_h, 4, 1});
+    latent.fill_(0.0f);
+
+    sd_latent_t* result = new sd_latent_t();
+    result->tensor      = std::move(latent);
+    return result;
+}
+
+SD_API sd_latent_t* sd_encode_image(
+    sd_ctx_t* sd_ctx,
+    const sd_image_t* image) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || image == nullptr || image->data == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->first_stage_model == nullptr) {
+        LOG_ERROR("first_stage_model (VAE) is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0                     = ggml_time_ms();
+    sd::Tensor<float> image_tensor = sd_image_to_tensor(*image, image->width, image->height);
+    sd::Tensor<float> latent       = sd_ctx->sd->encode_first_stage(image_tensor);
+
+    if (latent.empty()) {
+        LOG_ERROR("encode_first_stage failed");
+        return nullptr;
+    }
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_encode_image completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    if (sd_ctx->sd->free_params_immediately) {
+        sd_ctx->sd->first_stage_model->free_params_buffer();
+    }
+
+    sd_latent_t* result = new sd_latent_t();
+    result->tensor      = std::move(latent);
+    return result;
+}
+
+SD_API sd_image_t* sd_decode_latent(
+    sd_ctx_t* sd_ctx,
+    const sd_latent_t* latent) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || latent == nullptr) {
+        return nullptr;
+    }
+    if (sd_ctx->sd->first_stage_model == nullptr) {
+        LOG_ERROR("first_stage_model (VAE) is not loaded");
+        return nullptr;
+    }
+
+    int64_t t0                     = ggml_time_ms();
+    sd::Tensor<float> image_tensor = sd_ctx->sd->decode_first_stage(latent->tensor);
+
+    if (image_tensor.empty()) {
+        LOG_ERROR("decode_first_stage failed");
+        if (sd_ctx->sd->free_params_immediately) {
+            sd_ctx->sd->first_stage_model->free_params_buffer();
+        }
+        return nullptr;
+    }
+
+    int64_t t1 = ggml_time_ms();
+    LOG_INFO("sd_decode_latent completed in %.2fs", (t1 - t0) * 1.0f / 1000);
+
+    if (sd_ctx->sd->free_params_immediately) {
+        sd_ctx->sd->first_stage_model->free_params_buffer();
+    }
+
+    sd_image_t* result = (sd_image_t*)malloc(sizeof(sd_image_t));
+    if (result == nullptr) {
+        return nullptr;
+    }
+    *result = tensor_to_sd_image(image_tensor);
+    return result;
+}
+
+SD_API void sd_free_latent(sd_latent_t* latent) {
+    delete latent;
+}
