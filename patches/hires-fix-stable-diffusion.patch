+// ============================================================================
+// Conditioning Concat / Average - Added by my-img project
+// ============================================================================
+
+SD_API sd_conditioning_t* sd_conditioning_concat(const sd_conditioning_t* cond1,
+                                                 const sd_conditioning_t* cond2) {
+    if (cond1 == nullptr || cond2 == nullptr) {
+        return nullptr;
+    }
+
+    try {
+        sd_conditioning_t* result = new sd_conditioning_t();
+        result->cond              = cond1->cond;
+
+        if (!cond2->cond.c_crossattn.empty()) {
+            if (result->cond.c_crossattn.empty()) {
+                result->cond.c_crossattn = cond2->cond.c_crossattn;
+            } else {
+                result->cond.c_crossattn = sd::ops::concat(
+                    result->cond.c_crossattn, cond2->cond.c_crossattn, 1);
+            }
+        }
+
+        if (!cond2->cond.c_concat.empty()) {
+            if (result->cond.c_concat.empty()) {
+                result->cond.c_concat = cond2->cond.c_concat;
+            } else {
+                result->cond.c_concat = sd::ops::concat(
+                    result->cond.c_concat, cond2->cond.c_concat, 1);
+            }
+        }
+
+        return result;
+    } catch (const std::bad_alloc&) {
+        LOG_ERROR("sd_conditioning_concat: memory allocation failed");
+        return nullptr;
+    }
+}
+
+SD_API sd_conditioning_t* sd_conditioning_average(const sd_conditioning_t* cond1,
+                                                  const sd_conditioning_t* cond2,
+                                                  float conditioning_to_strength) {
+    if (cond1 == nullptr || cond2 == nullptr) {
+        return nullptr;
+    }
+
+    try {
+        sd_conditioning_t* result = new sd_conditioning_t();
+        float w1                  = 1.0f - conditioning_to_strength;
+        float w2                  = conditioning_to_strength;
+
+        if (!cond1->cond.c_crossattn.empty() && !cond2->cond.c_crossattn.empty()) {
+            result->cond.c_crossattn = cond1->cond.c_crossattn * w1 + cond2->cond.c_crossattn * w2;
+        } else if (!cond1->cond.c_crossattn.empty()) {
+            result->cond.c_crossattn = cond1->cond.c_crossattn;
+        } else if (!cond2->cond.c_crossattn.empty()) {
+            result->cond.c_crossattn = cond2->cond.c_crossattn;
+        }
+
+        if (!cond1->cond.c_concat.empty() && !cond2->cond.c_concat.empty()) {
+            result->cond.c_concat = cond1->cond.c_concat * w1 + cond2->cond.c_concat * w2;
+        } else if (!cond1->cond.c_concat.empty()) {
+            result->cond.c_concat = cond1->cond.c_concat;
+        } else if (!cond2->cond.c_concat.empty()) {
+            result->cond.c_concat = cond2->cond.c_concat;
+        }
+
+        return result;
+    } catch (const std::bad_alloc&) {
+        LOG_ERROR("sd_conditioning_average: memory allocation failed");
+        return nullptr;
+    }
+}
