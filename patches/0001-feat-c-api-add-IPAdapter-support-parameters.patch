From f88b11f8983e46c993e0b7be7d32340efede7806 Mon Sep 17 00:00:00 2001
From: quqiufeng <quqiufeng@gmail.com>
Date: Tue, 28 Apr 2026 11:55:37 +0800
Subject: [PATCH] feat(c-api): add IPAdapter support parameters

Add ipadapter_path to sd_ctx_params_t for model loading.
Add ipadapter_image and ipadapter_strength to sd_img_gen_params_t
for reference image and weight control.

This enables IPAdapter image prompting through the C API without
modifying internal UNet structure.
---
 include/stable-diffusion.h | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/include/stable-diffusion.h b/include/stable-diffusion.h
index 274c77c..b2ace8a 100755
--- a/include/stable-diffusion.h
+++ b/include/stable-diffusion.h
@@ -177,6 +177,7 @@ typedef struct {
     const sd_embedding_t* embeddings;
     uint32_t embedding_count;
     const char* photo_maker_path;
+    const char* ipadapter_path;       // IPAdapter model path
     const char* tensor_type_rules;
     bool vae_decode_only;
     bool free_params_immediately;
@@ -310,6 +311,8 @@ typedef struct {
     sd_image_t control_image;
     float control_strength;
     sd_pm_params_t pm_params;
+    sd_image_t ipadapter_image;   // Reference image for IPAdapter
+    float ipadapter_strength;      // IPAdapter weight (0.0-1.0)
     sd_tiling_params_t vae_tiling_params;
     sd_cache_params_t cache;
     bool enable_hires;
-- 
2.43.0

