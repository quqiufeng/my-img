+// ============================================================================
+// LoRA Support - Added by my-img project
+// ============================================================================
+
+SD_API void sd_apply_loras(
+    sd_ctx_t* sd_ctx,
+    const sd_lora_t* loras,
+    uint32_t lora_count) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr) {
+        return;
+    }
+    sd_ctx->sd->apply_loras(loras, lora_count);
+}
+
+SD_API void sd_clear_loras(sd_ctx_t* sd_ctx) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr) {
+        return;
+    }
+    sd_ctx->sd->apply_loras(nullptr, 0);
+}

