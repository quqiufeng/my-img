{
    "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
            "ckpt_name": "/path/to/model.gguf",
            "use_gpu": true,
            "flash_attn": false
        }
    },
    "2": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "masterpiece, best quality, a beautiful sunset over mountains",
            "clip": ["1", 1],
            "clip_skip": -1
        }
    },
    "3": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "worst quality, low quality, blurry",
            "clip": ["1", 1],
            "clip_skip": -1
        }
    },
    "4": {
        "class_type": "EmptyLatentImage",
        "inputs": {
            "width": 512,
            "height": 512,
            "batch_size": 1
        }
    },
    "5": {
        "class_type": "KSampler",
        "inputs": {
            "model": ["1", 0],
            "seed": 42,
            "steps": 20,
            "cfg": 7.5,
            "sampler_name": "euler",
            "scheduler": "normal",
            "positive": ["2", 0],
            "negative": ["3", 0],
            "latent_image": ["4", 0]
        }
    },
    "6": {
        "class_type": "VAEDecode",
        "inputs": {
            "samples": ["5", 0],
            "vae": ["1", 2]
        }
    },
    "7": {
        "class_type": "SaveImage",
        "inputs": {
            "images": ["6", 0],
            "filename_prefix": "txt2img_output"
        }
    }
}
