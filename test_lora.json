{
    "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
            "ckpt_name": "/path/to/model.gguf"
        }
    },
    "2": {
        "class_type": "LoRALoader",
        "inputs": {
            "lora_name": "/path/to/lora.safetensors",
            "strength_model": 0.8,
            "strength_clip": 0.8
        }
    },
    "3": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "masterpiece, best quality, a beautiful sunset over mountains",
            "clip": ["1", 1]
        }
    },
    "4": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "worst quality, low quality, blurry",
            "clip": ["1", 1]
        }
    },
    "5": {
        "class_type": "EmptyLatentImage",
        "inputs": {
            "width": 512,
            "height": 512,
            "batch_size": 1
        }
    },
    "6": {
        "class_type": "KSampler",
        "inputs": {
            "model": ["1", 0],
            "seed": 42,
            "steps": 20,
            "cfg": 7.5,
            "sampler_name": "euler",
            "scheduler": "normal",
            "positive": ["3", 0],
            "negative": ["4", 0],
            "latent_image": ["5", 0],
            "denoise": 1.0,
            "lora_stack": ["2", 0]
        }
    },
    "7": {
        "class_type": "VAEDecode",
        "inputs": {
            "samples": ["6", 0],
            "vae": ["1", 2]
        }
    },
    "8": {
        "class_type": "SaveImage",
        "inputs": {
            "images": ["7", 0],
            "filename_prefix": "lora_output"
        }
    }
}
